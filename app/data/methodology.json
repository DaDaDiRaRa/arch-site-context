    "고령인구비율": {"formula": "(65세 이상 인구 ÷ 총인구) × 100", "note": "주민등록 5세별 인구 (DT_1B04005N)"},
    "유소년인구비율": {"formula": "(0~14세 인구 ÷ 총인구) × 100", "note": "주민등록 5세별 인구"},
    "생산가능인구비율": {"formula": "(15~64세 인구 ÷ 총인구) × 100", "note": "주민등록 5세별 인구"},
    "노년부양비": {"formula": "(65세 이상 인구 ÷ 15~64세 인구) × 100", "note": "생산가능인구 100명당 고령인구"},
