# arch-site-context (터읽기) — 환경변수 예시
# 실제 키를 채운 .env 는 절대 커밋 금지 (.gitignore 에 포함됨).
# CLAUDE.md 4장 참고.
#
# ▶ 코드가 실제로 읽는 키(os.getenv) = 15개 + 선택(VWORLD_DOMAIN):
#   KAKAO_KEY VWORLD_KEY KOSIS_KEY ANTHROPIC_API_KEY JUSO_API_KEY DATA_GO_KR_API_KEY
#   SGIS_KEY SGIS_SECRET KMA_KEY RONE_KEY NEIS_KEY SEOUL_API_KEY KOPIS_KEY CHILDCARE_INFO_KEY TMAP_KEY
# ▶ 아래 LIBRARY_KEY·SBIZ365_KEY·CULTURE_KEY·CHILDCARE_DETAIL_KEY 는 현재 코드가 안 읽음(미연결/보류) —
#   자리표시용. 문화시설은 DATA_GO_KR_API_KEY(B553457)로, 상권은 DATA_GO_KR_API_KEY(B553077)로 처리.

# 카카오 로컬 — 주소→좌표, 반경 키워드 검색 (모드 B)
KAKAO_KEY=

# VWorld — 항공영상 타일 (모드 B). 도메인 잠금일 수 있음 → 안 되면 카카오 스카이뷰 폴백
VWORLD_KEY=

# KOSIS OpenAPI — 지역 통계 (모드 A). HTTPS 필수, 분당 호출 제한 → 캐시 우선
KOSIS_KEY=

# Claude API — 한 문단 서술(모드 A P6)·물어보기(P10)·종합산출(S4). narrative·ask 는 claude-opus-4-8.
ANTHROPIC_API_KEY=

# JUSO 행안부 도로명주소 — 카카오 주소검색 0건 시 정규화·법정동코드 폴백 (P1.6). 현재 dev키 → 운영키 교체 예정.
JUSO_API_KEY=

# data.go.kr 공공데이터포털 — 단일 키로 다수 데이터셋: 에어코리아 대기질·실거래(molit)·건축물대장(건축HUB)·
# 상권 B553077(sangwon)·문화기반시설총람 B553457(culture) 등. 데이터셋별 활용신청 승인돼야 실데이터.
DATA_GO_KR_API_KEY=

# 통계청 SGIS — 반경 집계구 실인구(D2)·재해위험(홍수·산사태·폭염). consumer_key + consumer_secret 2개.
# 신청: https://sgis.kostat.go.kr/developer → 서비스 신청 후 2키 발급 (services/sgis.py).
SGIS_KEY=
SGIS_SECRET=

# (선택) VWorld 등록 도메인 — 개별공시지가 호출의 domain 파라미터. 미설정 시 배포 서비스 호스트 기본값 (services/vworld.py).
# VWORLD_DOMAIN=

# (선택) VWorld Referer 헤더가 필요한 경우
# VWORLD_REFERER=

# 도서관정보나루 — 도서관 현황·장서 (P14). 승인 후 키 입력.
# 신청: https://www.data4library.kr  → 현재 승인 대기 중
LIBRARY_KEY=

# 서울 열린데이터광장 — 생활인구·지하철혼잡도 등 (P14). 키 1개로 모든 서비스 공유.
# 신청: https://data.seoul.go.kr  → 회원가입 후 인증키 자동 발급
# 호출형식: openapi.seoul.go.kr:8088/{KEY}/{형식}/{서비스명}/{시작}/{끝}/
SEOUL_API_KEY=

# 한국부동산원 R-ONE OpenAPI — 지가변동률·상업용임대동향·아파트동향 (P14). 키 1개로 전체 공유.
# 신청: https://www.reb.or.kr/r-one/portal/openapi/openApiIntroPage.do
# 구조: KOSIS와 유사 (STATBL_ID = tblId). XML 응답.
RONE_KEY=

# 기상청 API Hub — 단기예보·실황·기후통계 전체 (P15). 키 1개로 모든 KMA API 공유.
# 신청: https://apihub.kma.go.kr
# 활용 API: 단기예보조회·초단기실황·격자변환 + 기온·일사·일조·바람·강수량·적설 기후통계
KMA_KEY=

# TMAP Developers — 대중교통/자동차 이동시간·경로 (P15, 교통·접근성 #103).
# 신청: https://tmapapi.sktelecom.com  → 앱 등록 후 appKey 발급
# 호출 시 헤더 appKey 로 전달. 무료 일일 호출 한도 있음 → 캐시 우선.
TMAP_KEY=

# 소상공인 365 (상권정보) — 상권분석·매출·점포수·폐업률·빈상가 (P14, 경제·상권 #29·#30).
# 신청: https://www.sbiz365.or.kr (소상공인시장진흥공단)  → 키 발급 완료 (2026-06-26)
SBIZ365_KEY=

# NEIS 교육정보 개발포털 — 학교 현황·학생수·학급수·학교기본정보 (P14, 교육 #117).
# 신청: https://open.neis.go.kr  → 인증키 발급. 호출 시 KEY 파라미터로 전달, Type=json.
NEIS_KEY=

# 문화공공데이터광장 — 한국문화정보원 문화기반시설 통계정보 (P14, 문화·여가 #134).
# 도서관·박물관·미술관·문예회관·지방문화원 등 문화기반시설 통계.
# 신청: https://www.culture.go.kr/data  → 활용신청 후 인증키 발급.
CULTURE_KEY=

# KOPIS 공연예술통합전산망 (예술경영지원센터) — 공연시설별 통계 (P14, 문화·여가 #134).
# 신청: https://www.kopis.or.kr  → OpenAPI 서비스키 발급. 호출 시 service 파라미터로 전달.
KOPIS_KEY=

# 어린이집 정보공개포털 OpenAPI — 어린이집 목록·상세 조회 (#126 보완).
# 신청: https://openapi.childcare.go.kr  → API별 인증키 발급 (API마다 키가 다름).
#   CHILDCARE_INFO_KEY   = cpmsapi021("어린이집별 정보 조회"). services/childcare.py 사용.
#                          호출: key=인증키 & arcode=시군구5자리 → 개수·정원 (XML).
#   CHILDCARE_DETAIL_KEY = cpmsapi030(상세: 위경도·CCTV·연령별정원). arcode 체계 별도 — 미연결.
CHILDCARE_INFO_KEY=
CHILDCARE_DETAIL_KEY=
