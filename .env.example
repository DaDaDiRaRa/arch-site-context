# arch-site-context (터읽기) — 환경변수 예시
# 실제 키를 채운 .env 는 절대 커밋 금지 (.gitignore 에 포함됨).
# CLAUDE.md 4장 참고.

# 카카오 로컬 — 주소→좌표, 반경 키워드 검색 (모드 B)
KAKAO_KEY=

# VWorld — 항공영상 타일 (모드 B). 도메인 잠금일 수 있음 → 안 되면 카카오 스카이뷰 폴백
VWORLD_KEY=

# KOSIS OpenAPI — 지역 통계 (모드 A). HTTPS 필수, 분당 호출 제한 → 캐시 우선
KOSIS_KEY=

# Claude API — 한 문단 서술 1회 (모드 A, P6)
ANTHROPIC_API_KEY=

# (선택) VWorld Referer 헤더가 필요한 경우
# VWORLD_REFERER=

# 한국부동산원 R-ONE OpenAPI — 지가변동률·상업용임대동향·아파트동향 (P14). 키 1개로 전체 공유.
# 신청: https://www.reb.or.kr/r-one/portal/openapi/openApiIntroPage.do
# 구조: KOSIS와 유사 (STATBL_ID = tblId). XML 응답.
RONE_KEY=

# 기상청 API Hub — 단기예보·실황·기후통계 전체 (P15). 키 1개로 모든 KMA API 공유.
# 신청: https://apihub.kma.go.kr
# 활용 API: 단기예보조회·초단기실황·격자변환 + 기온·일사·일조·바람·강수량·적설 기후통계
KMA_KEY=
